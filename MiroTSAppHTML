<!DOCTYPE html>
<html lang="en">
<head>
  <script src="https://miro.com/app/static/sdk/v2/miro.js"></script>
  <style>
    button {
      width: 100%;
      padding: 12px;
      margin-top: 10px;
      background-color: #0500FF;
      color: white;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-weight: bold;
